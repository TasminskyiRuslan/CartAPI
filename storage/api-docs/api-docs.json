{
    "openapi": "3.0.0",
    "info": {
        "title": "Cart API",
        "description": "API documentation for the Cart API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080/api",
            "description": "Local development server"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Authenticate user",
                "description": "Authenticate a user using email and password and issue an access token.",
                "operationId": "8e026335d25c3df3f6f6cf1f683ac7b8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginUserRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "User authenticated successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/AuthResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Invalid credentials or validation error."
                    }
                },
                "security": [
                    {
                        "guest_token": []
                    },
                    {}
                ]
            }
        },
        "/auth/logout": {
            "delete": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout user",
                "description": "Revoke the current access token for the authenticated user.",
                "operationId": "23a3ec5e2e8d20c9fd2ea568ae96fcd3",
                "responses": {
                    "204": {
                        "description": "User logged out successfully."
                    },
                    "401": {
                        "description": "Unauthenticated."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Get current user",
                "description": "Return the currently authenticated user.",
                "operationId": "a27984a716a6787c8b8537aee958673c",
                "responses": {
                    "200": {
                        "description": "User retrieved successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/UserResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register user",
                "description": "Register a new user and issue an access token.",
                "operationId": "8e69ddc577b1650c4a010f798dd6c9d3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterUserRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/AuthResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error."
                    }
                },
                "security": [
                    {
                        "guest_token": []
                    },
                    {}
                ]
            }
        },
        "/cart": {
            "get": {
                "tags": [
                    "Cart"
                ],
                "summary": "Get current cart",
                "description": "Returns the active cart for the authenticated user or guest.",
                "operationId": "8f16b385b0bec46faad2136254a7ef52",
                "responses": {
                    "200": {
                        "description": "Cart retrieved successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/CartResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    },
                    {
                        "guest_token": []
                    },
                    {}
                ]
            },
            "delete": {
                "tags": [
                    "Cart"
                ],
                "summary": "Delete current cart",
                "description": "Deletes the active cart for the authenticated user or guest.",
                "operationId": "87ae7ca34713e7228f1422e3cafa31c5",
                "responses": {
                    "204": {
                        "description": "The cart deleted."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    },
                    {
                        "guest_token": []
                    }
                ]
            }
        },
        "/cart/items": {
            "post": {
                "tags": [
                    "Cart"
                ],
                "summary": "Add item to cart",
                "description": "Adds a product to the cart or increases its quantity if it already exists.",
                "operationId": "d6674e21902278d2c2b278acd30ccb91",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateCartItemRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Item added to cart.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/CartResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "Item quantity increased.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/CartResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    },
                    {
                        "guest_token": []
                    }
                ]
            }
        },
        "/cart/items/{item}": {
            "patch": {
                "tags": [
                    "Cart"
                ],
                "summary": "Update cart item quantity",
                "description": "Updates the quantity of a specific cart item.",
                "operationId": "15ea169f0896ec8b11469b74103458ab",
                "parameters": [
                    {
                        "name": "item",
                        "in": "path",
                        "description": "Cart item identifier",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateCartItemRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Item quantity updated.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/CartResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Cart item not found."
                    },
                    "422": {
                        "description": "Validation error."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    },
                    {
                        "guest_token": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "LoginUserRequest": {
                "title": "Login User Request",
                "description": "Request payload for authenticating a user.",
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "description": "User email address.",
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "john@example.com"
                    },
                    "password": {
                        "description": "User account password.",
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "RegisterUserRequest": {
                "title": "Register User Request",
                "description": "Request payload for registering a new user.",
                "required": [
                    "name",
                    "email",
                    "password",
                    "password_confirmation"
                ],
                "properties": {
                    "name": {
                        "description": "Full name of the user.",
                        "type": "string",
                        "maxLength": 100,
                        "example": "John Doe"
                    },
                    "email": {
                        "description": "User email address.",
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "john@example.com"
                    },
                    "password": {
                        "description": "User account password.",
                        "type": "string",
                        "format": "password",
                        "minLength": 8,
                        "example": "password123"
                    },
                    "password_confirmation": {
                        "description": "Password confirmation (must match password).",
                        "type": "string",
                        "format": "password",
                        "minLength": 8,
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "CreateCartItemRequest": {
                "title": "Create Cart Item Request",
                "description": "Request payload for adding a product to the cart.",
                "required": [
                    "product_id"
                ],
                "properties": {
                    "product_id": {
                        "description": "ID of the product to add.",
                        "type": "integer",
                        "example": 1
                    },
                    "quantity": {
                        "description": "Quantity of the product.",
                        "type": "integer",
                        "maximum": 99,
                        "minimum": 1,
                        "example": 2
                    }
                },
                "type": "object"
            },
            "UpdateCartItemRequest": {
                "title": "Update Cart Item Request",
                "description": "Request payload for updating a product quantity in the cart.",
                "required": [
                    "quantity"
                ],
                "properties": {
                    "quantity": {
                        "description": "New quantity of the product.",
                        "type": "integer",
                        "maximum": 99,
                        "minimum": 1,
                        "example": 2
                    }
                },
                "type": "object"
            },
            "AuthResponse": {
                "title": "Auth Response",
                "description": "Data returned after user login or registration.",
                "required": [
                    "user",
                    "access_token",
                    "token_type"
                ],
                "properties": {
                    "user": {
                        "$ref": "#/components/schemas/UserResponse"
                    },
                    "access_token": {
                        "description": "Personal access token for API authentication.",
                        "type": "string",
                        "example": "1|eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..."
                    },
                    "token_type": {
                        "description": "Token type to be used in the Authorization header.",
                        "type": "string",
                        "example": "Bearer"
                    }
                },
                "type": "object"
            },
            "UserResponse": {
                "title": "User Response",
                "description": "Data for a user.",
                "required": [
                    "id",
                    "name",
                    "email"
                ],
                "properties": {
                    "id": {
                        "description": "Unique identifier of the user.",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "Full name of the user.",
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "description": "Email address of the user.",
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    }
                },
                "type": "object"
            },
            "CartItemResponse": {
                "title": "Cart Item Response",
                "description": "Data for a single item in the cart.",
                "required": [
                    "id",
                    "price_snapshot",
                    "quantity",
                    "total_price",
                    "product"
                ],
                "properties": {
                    "id": {
                        "description": "Unique identifier of the cart item.",
                        "type": "integer",
                        "example": 1
                    },
                    "price_snapshot": {
                        "description": "Product price at the time it was added to the cart.",
                        "type": "string",
                        "format": "float",
                        "example": 999.99
                    },
                    "quantity": {
                        "description": "Quantity of the product in the cart.",
                        "type": "integer",
                        "example": 2
                    },
                    "total_price": {
                        "description": "Total price for this item (price_snapshot * quantity).",
                        "type": "string",
                        "format": "float",
                        "example": 1999.98
                    },
                    "product": {
                        "$ref": "#/components/schemas/ProductResponse"
                    }
                },
                "type": "object"
            },
            "CartResponse": {
                "title": "Cart Response",
                "description": "Data for a user cart.",
                "required": [
                    "id",
                    "items",
                    "total_price",
                    "total_count"
                ],
                "properties": {
                    "id": {
                        "description": "Unique identifier of the cart.",
                        "type": "integer",
                        "example": 1
                    },
                    "items": {
                        "description": "List of items in the cart.",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CartItemResponse"
                        }
                    },
                    "total_price": {
                        "description": "Total price of all items in the cart.",
                        "type": "string",
                        "format": "float",
                        "example": 1999.98
                    },
                    "total_count": {
                        "description": "Total number of items in the cart.",
                        "type": "integer",
                        "example": 2
                    }
                },
                "type": "object"
            },
            "ProductResponse": {
                "title": "Product Response",
                "description": "Data for a product.",
                "required": [
                    "id",
                    "name",
                    "price"
                ],
                "properties": {
                    "id": {
                        "description": "The product ID.",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "The product name.",
                        "type": "string",
                        "example": "iPhone 15 Pro"
                    },
                    "description": {
                        "description": "The product description.",
                        "type": "string",
                        "example": "New iPhone with powerful processor and Pro camera",
                        "nullable": true
                    },
                    "price": {
                        "description": "The product price.",
                        "type": "string",
                        "format": "float",
                        "example": 999.99
                    },
                    "image_path": {
                        "description": "The image of the product.",
                        "type": "string",
                        "format": "path",
                        "example": "products/product1.png",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Enter token in format: Bearer {token}",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            },
            "guest_token": {
                "type": "apiKey",
                "description": "Token for guest cart identification generated by frontend",
                "name": "Guest-Token",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Cart",
            "description": "Cart"
        }
    ]
}