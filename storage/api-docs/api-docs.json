{
    "openapi": "3.0.0",
    "info": {
        "title": "Cart API",
        "description": "API documentation for the Cart API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080/api",
            "description": "Local development server"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login",
                "description": "Authenticate user.",
                "operationId": "8e026335d25c3df3f6f6cf1f683ac7b8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginUserRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "User logged in",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Auth"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/auth/logout": {
            "delete": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout current device",
                "description": "Revoke the authentication token for the authenticated user.",
                "operationId": "23a3ec5e2e8d20c9fd2ea568ae96fcd3",
                "responses": {
                    "204": {
                        "description": "User logged out"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Get authenticated user",
                "description": "Get the authenticated user's data.",
                "operationId": "a27984a716a6787c8b8537aee958673c",
                "responses": {
                    "200": {
                        "description": "Authenticated user data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register",
                "description": "Register a new user.",
                "operationId": "8e69ddc577b1650c4a010f798dd6c9d3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterUserRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Auth"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/cart": {
            "get": {
                "tags": [
                    "Cart"
                ],
                "summary": "Get current cart",
                "description": "Get the current cart for the user.",
                "operationId": "8f16b385b0bec46faad2136254a7ef52",
                "responses": {
                    "200": {
                        "description": "The cart data returned.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Cart"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    },
                    {
                        "guest_token": []
                    },
                    {}
                ]
            },
            "delete": {
                "tags": [
                    "Cart"
                ],
                "summary": "Delete current cart",
                "description": "Delete the current cart for the user.",
                "operationId": "87ae7ca34713e7228f1422e3cafa31c5",
                "responses": {
                    "204": {
                        "description": "The cart deleted."
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    },
                    {
                        "guest_token": []
                    },
                    {}
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "LoginUserRequest": {
                "title": "Login User Request Schema",
                "description": "Schema for user login via API request",
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "description": "Email of the user",
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "john@example.com"
                    },
                    "password": {
                        "description": "Password of the user",
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "RegisterUserRequest": {
                "title": "Register User Request Schema",
                "description": "Schema for user registration via API request",
                "required": [
                    "name",
                    "email",
                    "password",
                    "password_confirmation"
                ],
                "properties": {
                    "name": {
                        "description": "Name of the user",
                        "type": "string",
                        "maxLength": 100,
                        "example": "John Doe"
                    },
                    "email": {
                        "description": "Email of the user",
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "john@example.com"
                    },
                    "password": {
                        "description": "Password of the user",
                        "type": "string",
                        "format": "password",
                        "minLength": 8,
                        "example": "password123"
                    },
                    "password_confirmation": {
                        "description": "Password Confirmation of the user",
                        "type": "string",
                        "format": "password",
                        "minLength": 8,
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "Auth": {
                "title": "Auth Schema",
                "description": "Authentication data returned by the API",
                "required": [
                    "user",
                    "access_token",
                    "token_type"
                ],
                "properties": {
                    "user": {
                        "$ref": "#/components/schemas/User"
                    },
                    "access_token": {
                        "description": "Access token",
                        "type": "string",
                        "example": "1|eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..."
                    },
                    "token_type": {
                        "description": "Type of the token for Authorization header",
                        "type": "string",
                        "example": "Bearer"
                    }
                },
                "type": "object"
            },
            "User": {
                "title": "User Schema",
                "description": "User data returned by the API",
                "required": [
                    "id",
                    "name",
                    "email",
                    "created_at",
                    "updated_at"
                ],
                "properties": {
                    "id": {
                        "description": "The user ID",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "The user name",
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "description": "The user email",
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    }
                },
                "type": "object"
            },
            "CartItem": {
                "title": "Cart Item Schema",
                "description": "Details of a cart item returned by the API",
                "required": [
                    "id",
                    "price_snapshot",
                    "quantity",
                    "total_price",
                    "product"
                ],
                "properties": {
                    "id": {
                        "description": "The product ID",
                        "type": "integer",
                        "example": 1
                    },
                    "price_snapshot": {
                        "description": "The product price at the time it was added to the cart",
                        "type": "string",
                        "format": "float",
                        "example": 999.99
                    },
                    "quantity": {
                        "description": "The quantity of the product in the cart",
                        "type": "integer",
                        "example": 2
                    },
                    "total_price": {
                        "description": "The total price for this cart item (price_snapshot * quantity)",
                        "type": "string",
                        "format": "float",
                        "example": 1999.98
                    },
                    "product": {
                        "$ref": "#/components/schemas/Product"
                    }
                },
                "type": "object"
            },
            "Cart": {
                "title": "Cart schema",
                "description": "The cart data returned by the API",
                "required": [
                    "id",
                    "items",
                    "total_price",
                    "total_count"
                ],
                "properties": {
                    "id": {
                        "description": "The cart ID",
                        "type": "integer",
                        "example": 1
                    },
                    "items": {
                        "description": "The cart items",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CartItem"
                        }
                    },
                    "total_price": {
                        "description": "The total price of the cart",
                        "type": "string",
                        "format": "float",
                        "example": 1999.98
                    },
                    "total_count": {
                        "description": "The total count of the cart",
                        "type": "integer",
                        "example": 2
                    }
                },
                "type": "object"
            },
            "Product": {
                "title": "Product Schema",
                "description": "Details of a product returned by the API",
                "required": [
                    "id",
                    "name",
                    "price"
                ],
                "properties": {
                    "id": {
                        "description": "The product ID",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "The product name",
                        "type": "string",
                        "example": "iPhone 15 Pro"
                    },
                    "description": {
                        "description": "The product description",
                        "type": "string",
                        "example": "New iPhone with powerful processor and Pro camera",
                        "nullable": true
                    },
                    "price": {
                        "description": "The product price",
                        "type": "string",
                        "format": "float",
                        "example": 999.99
                    },
                    "image_path": {
                        "description": "The image of the product",
                        "type": "string",
                        "format": "path",
                        "example": "products/product1.png",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Enter token in format: Bearer {token}",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            },
            "guest_token": {
                "type": "apiKey",
                "description": "Token for guest cart identification generated by frontend",
                "name": "X-Guest-Token",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Cart",
            "description": "Cart"
        }
    ]
}